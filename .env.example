# =============================================================================
# LLM Configuration
# =============================================================================

# Ollama server URL
# For local Ollama: http://127.0.0.1:11434
# For Ollama cloud: https://ollama.com
OLLAMA_HOST=http://127.0.0.1:11434

# Model name (default: glm-5:cloud)
OLLAMA_MODEL=glm-5:cloud

# API key for cloud models (optional, required for ollama.com)
# OLLAMA_API_KEY=your_api_key

# =============================================================================
# Agent Behavior Configuration
# =============================================================================

# Token threshold for auto-compacting (default: 50000)
# MYCC_TOKEN_THRESHOLD=50000

# Todo nudge interval in turns (default: 3)
# MYCC_TODO_NUDGE_INTERVAL=3

# =============================================================================
# Timeout Configuration (in milliseconds)
# =============================================================================

# Bash command timeout (default: 120000 = 2 minutes)
# MYCC_BASH_TIMEOUT=120000

# Team await timeout (default: 60000 = 1 minute)
# MYCC_TEAM_TIMEOUT=60000

# =============================================================================
# Storage Configuration
# =============================================================================

# Data directory name (default: .mycc)
# MYCC_DATA_DIR=.mycc