{
  "name": "mycc",
  "version": "0.1.0",
  "description": "Node.js agent implementations using Ollama - harness engineering for AI agents",
  "type": "module",
  "bin": {
    "mycc": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.0.0",
    "execa": "^9.6.1",
    "gray-matter": "^4.0.3",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chalk": "^0.4.31",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
